<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YT Notifications</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="header">
    <div class="container header-inner">
      <a href="/" class="title-link" title="Home"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 3L4 9v12h5v-7h6v7h5V9z"/></svg></a>
      <button id="notifToggle" class="notif-btn" onclick="app.toggleNotif()"></button>
      <select id="limitSelect" class="limit-select" onchange="app.changeLimit(this.value)"></select>
      <button id="newIndicatorBtn" class="new-indicator-btn" title="New notifications" onclick="app.goTo(0)"><span id="newIndicator" class="new-indicator"></span></button>
    </div>
  </div>

  <div class="container">
    <div class="container-inner">
      <div id="notifList"><div class="spinner"></div></div>
    </div>
  </div>

  <div class="pagination" id="pagination"></div>

  <script src="/app.js"></script>
</body>
</html>
